{
  "name": "@wroud/vite-plugin-ssg",
  "description": "A Vite plugin for static site generation (SSG) with React. Renders React applications to static HTML for faster load times and improved SEO. ",
  "version": "7.0.0",
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": "./lib/ssgPlugin.js",
    "./*": "./lib/*.js"
  },
  "scripts": {
    "ci:release": "ci release --prefix vite-plugin-ssg-v",
    "ci:git-tag": "ci git-tag --prefix vite-plugin-ssg-v",
    "ci:release-github": "ci release-github --prefix vite-plugin-ssg-v",
    "build": "tsc -b",
    "watch:tsc": "tsc -b -w",
    "clear": "rimraf lib",
    "test": "tests-runner"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "lib",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!lib/**/*.d.ts.map",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts",
    "!lib/**/*.test.d.ts.map",
    "!lib/**/*.test.js.map",
    "!.tsbuildinfo"
  ],
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3",
    "@wroud/ci": "workspace:^0",
    "@wroud/di": "workspace:^",
    "@wroud/di-react": "workspace:^",
    "@wroud/tests-runner": "workspace:*",
    "@wroud/tsconfig": "workspace:^",
    "react": "^19",
    "react-dom": "^19",
    "rimraf": "^6",
    "rolldown": "^1",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^3"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6",
    "@vitejs/plugin-rsc": "^0.5",
    "rsc-html-stream": "^0",
    "tinyglobby": "^0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "static-site-generation",
    "ssg",
    "react",
    "static-rendering",
    "html-generation",
    "vite-ssg",
    "pre-rendering",
    "SEO"
  ]
}
